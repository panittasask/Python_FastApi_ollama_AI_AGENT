# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=600

# --- Models ---
REFINER_MODEL=qwen2.5:7b
CODER_MODEL=deepseek-coder:6.7b
FIX_MODEL=codellama:13b
PLANNER_MODEL=qwen2.5:7b

# --- Generation params ---
TEMPERATURE=0.2
TOP_P=0.9
MAX_TOKENS=8192
NUM_CTX=8192

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
OUTPUT_DIR=./generated_projects
MAX_FIX_ITERATIONS=5
MAX_GENERATION_LOOPS=30
ENABLE_AUTO_TEST=true
